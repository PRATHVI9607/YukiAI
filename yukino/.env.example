# Yukino AI Environment Variables

# OpenRouter API Key (REQUIRED)
# Get your free API key from: https://openrouter.ai/keys
# 1. Visit https://openrouter.ai/ and create a free account
# 2. Go to https://openrouter.ai/keys
# 3. Create a new API key
# 4. Copy and paste it below (replace 'your_key_here')
OPENROUTER_API_KEY=your_key_here

# Optional: Picovoice Access Key (for Porcupine wakeword detection)
# Only needed if you set wakeword.method to "porcupine" in config.yaml
# Get from: https://console.picovoice.ai/
# PICOVOICE_ACCESS_KEY=your_key_here
